# SAC — environment configuration template.
# Copy to .env and fill in. NEVER commit a real .env file.

# AWS region where Bedrock image models are enabled
# (Stability image models are hosted in us-west-2)
AWS_DEFAULT_REGION=us-east-1
SAC_BEDROCK_REGION=us-west-2

# Standard AWS credential variables (leave empty to use ~/.aws or an
# instance/SSO profile instead)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
AWS_PROFILE=

# Optional: override the Bedrock image model
# (default: stability.stable-image-core-v1:1 — Titan v1/v2, Nova Canvas
# and SDXL are EOL/legacy on Bedrock as of 2026)
# SAC_BEDROCK_MODEL_ID=stability.stable-image-core-v1:1
